# Use Node 22 Alpine
FROM node:22-alpine

WORKDIR /app

# Install all dependencies (including dev for building)
COPY package*.json ./
RUN npm ci  # <-- remove --omit=dev so devDependencies are installed

# Copy source
COPY . .

# generate prisma client
RUN npx prisma generate

# Build TypeScript
RUN npm run build

# Expose port
EXPOSE 3000

# Run migrations THEN start server
CMD sh -c "sleep 5 && npx prisma db push && node dist/index.js"
